# Источник данных для фронта (CLAUDE.md §3).
# chain → ChainDataProvider (реальный кошелёк devnet + индексер, Фаза 3) — основной
# api   → ApiDataProvider   (бэкенд по HTTP, dev-вход по адресу без кошелька)
# mock  → MockDataProvider  (in-browser, dev-вход по адресу)
NEXT_PUBLIC_DATA_SOURCE=chain

# Сид мока для детерминированных фикстур/скриншотов (Фаза 1).
NEXT_PUBLIC_MOCK_SEED=standing-v0.1

# Инъекция ошибок в мок для прогона error-стейтов (mock-data.md §3). off по умолчанию.
NEXT_PUBLIC_MOCK_FAIL=off

# Фаза 3 (devnet). Нужны для режима chain — задаются после создания тестового USDC mint и трежери
# (см. scripts/devnet-smoke.ts / crypto/spec.md §2). Пусто → createDonation бросит NOT_CONFIGURED.
# NEXT_PUBLIC_DEVNET_USDC_MINT=
# NEXT_PUBLIC_TREASURY_OWNER=
